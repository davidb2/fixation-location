          RowBox[{"GrayLevel", "[", "0.15", "]"}], "]"}], ",", "\n", "    ", 
         "edges1", ",", "\n", "    ", 
         RowBox[{"Directive", "[", 
          RowBox[{"RGBColor", "[", 
           RowBox[{"0.2", ",", " ", "0.45", ",", " ", "0.85"}], "]"}], "]"}], 
         ",", "\n", "    ", "edges2", ",", "\n", "    ", 
