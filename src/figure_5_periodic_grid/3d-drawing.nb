          RowBox[{
           RowBox[{"Sphere", "[", 
            RowBox[{"#", ",", " ", "vertexRadius"}], "]"}], " ", "&"}], " ", "/@",
           " ", "verts"}]}], "\n", "  ", "}"}], "]"}], ",", "\n", "  ", 
