Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"n", "=", "11"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Torus", " ", 
    RowBox[{"radii", ":", 
     RowBox[{"increase", " ", 
      RowBox[{"R", "/", "r"}], " ", "to", " ", "make", " ", "the", " ", 
      "hole", " ", "more", " ", "pronounced"}]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"R", "=", "3.5"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"major", " ", "radius"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"r", "=", "1.2"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"minor", " ", "radius"}], "*)"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"edgeRadius", "=", "0.05"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vertexRadius", "=", "0.12"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"torusPoint", "[", 
     RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", ",", "v"}], "}"}], ",", 
      RowBox[{
       RowBox[{"u", "=", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{"i", "/", "n"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"v", "=", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{"j", "/", "n"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"R", "+", 
            RowBox[{"r", " ", 
             RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
          RowBox[{"Cos", "[", "u", "]"}]}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"R", "+", 
            RowBox[{"r", " ", 
             RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
          RowBox[{"Sin", "[", "u", "]"}]}], ",", 
         RowBox[{"r", " ", 
          RowBox[{"Sin", "[", "v", "]"}]}]}], "}"}]}]}], "]"}]}], ";"}], "\n",
   "\[IndentingNewLine]", 
  RowBox[{"(*", "Vertices", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"verts", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"torusPoint", "[", 
         RowBox[{"i", ",", "j"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Periodic", " ", "edges", " ", "in", " ", "the", " ", "two", " ", "grid", 
    " ", "directions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"edges1", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Tube", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"torusPoint", "[", 
             RowBox[{"i", ",", "j"}], "]"}], ",", 
            RowBox[{"torusPoint", "[", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{"i", "+", "1"}], ",", "n"}], "]"}], ",", "j"}], 
             "]"}]}], "}"}], ",", "edgeRadius"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"edges2", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Tube", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"torusPoint", "[", 
             RowBox[{"i", ",", "j"}], "]"}], ",", 
            RowBox[{"torusPoint", "[", 
             RowBox[{"i", ",", 
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{"j", "+", "1"}], ",", "n"}], "]"}]}], "]"}]}], "}"}], 
          ",", "edgeRadius"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "0", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Optional", " ", "torus", " ", "surface"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"surface", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"R", "+", 
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
         RowBox[{"Cos", "[", "u", "]"}]}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"R", "+", 
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "v", "]"}]}]}], ")"}], " ", 
         RowBox[{"Sin", "[", "u", "]"}]}], ",", 
        RowBox[{"r", " ", 
         RowBox[{"Sin", "[", "v", "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"u", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"v", ",", "0", ",", 
        RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
      RowBox[{"Mesh", "->", "None"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.18", "]"}], ",", "LightGray"}], "]"}]}], 
      ",", 
      RowBox[{"BoundaryStyle", "->", "None"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"surface", ",", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Directive", "[", 
       RowBox[{"GrayLevel", "[", "0.15", "]"}], "]"}], ",", "edges1", ",", 
      RowBox[{"Directive", "[", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.2", ",", "0.45", ",", "0.85"}], "]"}], "]"}], ",", 
      "edges2", ",", 
      RowBox[{"Directive", "[", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.85", ",", "0.2", ",", "0.2"}], "]"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Sphere", "[", 
         RowBox[{"#", ",", "vertexRadius"}], "]"}], "&"}], "/@", "verts"}]}], 
     "}"}], "]"}], ",", 
   RowBox[{"Boxed", "->", "False"}], ",", 
   RowBox[{"Axes", "->", "False"}], ",", 
   RowBox[{"Lighting", "->", "\"\<Neutral\>\""}], ",", 
   RowBox[{"Background", "->", "White"}], ",", 
   RowBox[{"ViewPoint", "->", 
    RowBox[{"{", 
     RowBox[{"2.2", ",", 
      RowBox[{"-", "2.4"}], ",", "1.4"}], "}"}]}], ",", 
   RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.985083464787939*^9, 3.985083464791224*^9}, {
  3.985083541114563*^9, 3.9850835499980707`*^9}},
